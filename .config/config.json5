{
  // Key into `themes` that is active at startup.
  defaultTheme: "catpuccineFrappe",

  // Named themes: each slot maps to palette colour names (and optional
  // modifiers). Colour names must exist in the matching palette entry.
  themes: {
    catpuccineFrappe: {
      popupSurface: { fg: "text",     bg: "mantle"   },
      keyLabel:     { fg: "peach"                    },
      border:       { fg: "surface0"                 },
      title:        { fg: "lavender"                 },
      header:       { fg: "blue"                     },
      selection:    { fg: "base",     bg: "mauve"    },
      columnFocus:  { fg: "lavender"                 },
      navBar:       { fg: "subtext0", bg: "surface0" },
      statusActive: { fg: "text",     bg: "surface0" },
      statusEmpty:  { fg: "overlay0", bg: "surface0" },
      safe:         { fg: "green"                    },
      caution:      { fg: "yellow"                   },
      danger:       { fg: "red"                      },
      bodyText:     { fg: "text"                     },
      hint:         { fg: "subtext0"                 },
    },
  },

  // Named palettes: map every colour slot to a hex value.
  palettes: {
    catpuccineFrappe: {
      rosewater: "#f2d5cf",
      flamingo:  "#eebebe",
      pink:      "#f4b8e4",
      mauve:     "#ca9ee6",
      red:       "#e78284",
      maroon:    "#ea999c",
      peach:     "#ef9f76",
      yellow:    "#e5c890",
      green:     "#a6d189",
      teal:      "#81c8be",
      sky:       "#99d1db",
      sapphire:  "#85c1dc",
      blue:      "#8caaee",
      lavender:  "#babbf1",
      text:      "#c6d0f5",
      subtext1:  "#b5bfe2",
      subtext0:  "#a5adce",
      overlay2:  "#949cbb",
      overlay1:  "#838ba7",
      overlay0:  "#737994",
      surface2:  "#626880",
      surface1:  "#51576d",
      surface0:  "#414559",
      base:      "#303446",
      mantle:    "#292c3c",
      crust:     "#232634",
    },
  },

  keybindings: {
    Home: {
      // select
      "<CR>": "Select",

      // movement
      j: "Down",
      k: "Up",
      h: "Left",
      l: "Right",
      "<Down>": "Down",
      "<Up>": "Up",
      "<Left>": "Left",
      "<Right>": "Right",

      // half-page scroll
      "<C-d>": "ScrollDown",
      "<C-u>": "ScrollUp",

      // full-page scroll
      "<C-f>": "PageDown",
      "<C-b>": "PageUp",
      "<PageDown>": "PageDown",
      "<PageUp>": "PageUp",

      // jump to start / end
      gg: "GotoTop",
      "<S-g>": "GotoBottom",
      "<Home>": "GotoTop",
      "<End>": "GotoBottom",
    },
  },
}
